#!/usr/bin/env bash
#
# m3claude — run Claude Code against TokenRouter's API with model MiniMax-M3.
#
# Key resolution order:
#   1. `m3claude config [KEY]`     — set/replace the stored key (inline or prompt)
#   2. stored config file          — set on a previous run
#   3. TOKENROUTER_API_KEY env var — used and saved for next time
#   4. interactive prompt          — asks for the key if you haven't included it yet
#
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/m3claude"
CONFIG_FILE="$CONFIG_DIR/config"

say() { printf '%s\n' "$*" >&2; }

# Trim leading/trailing whitespace.
trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

# Persist the key with owner-only permissions.
save_key() {
  local key
  key="$(trim "$1")"
  if [ -z "$key" ]; then
    say "Refusing to save an empty key."
    return 1
  fi
  mkdir -p "$CONFIG_DIR"
  ( umask 077; printf 'TOKENROUTER_API_KEY=%s\n' "$key" > "$CONFIG_FILE" )
  chmod 600 "$CONFIG_FILE"
  say "Key saved to $CONFIG_FILE"
}

read_key() {
  [ -f "$CONFIG_FILE" ] || return 0
  local line
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      TOKENROUTER_API_KEY=*) printf '%s' "${line#TOKENROUTER_API_KEY=}"; return 0 ;;
    esac
  done < "$CONFIG_FILE"
  return 0
}

# Read a secret from the terminal; fall back to stdin if /dev/tty is unusable.
read_secret() {
  local prompt="$1" value=""
  printf '%s' "$prompt" >&2
  if IFS= read -rs value 2>/dev/null < /dev/tty; then
    :
  else
    IFS= read -rs value || true
  fi
  printf '\n' >&2
  printf '%s' "$value"
}

# Interactive first-time setup.
interactive_setup() {
  say ""
  say "┌──────────────────────────────────────────┐"
  say "│  m3claude · first-time setup              │"
  say "└──────────────────────────────────────────┘"
  say ""
  say "Claude Code will run against TokenRouter's API."
  say "You only need to enter your key once."
  say "Get a key: https://tokenrouter.com"
  say ""
  local key="" tries=0
  while :; do
    key="$(trim "$(read_secret 'TokenRouter API key: ')")"
    [ -n "$key" ] && break
    tries=$((tries + 1))
    say "Key can't be empty."
    if [ "$tries" -ge 3 ]; then
      say "Aborting after 3 empty attempts."
      exit 1
    fi
  done
  save_key "$key"
  say ""
}

# --- subcommands -----------------------------------------------------------
case "${1:-}" in
  config|--config|set-key|--set-key|change|--change|change-key|--change-key)
    if [ "${2:-}" != "" ]; then
      save_key "$2"
    else
      interactive_setup
    fi
    say "Done. Run 'm3claude' to start."
    exit 0
    ;;
  reset|--reset)
    rm -f "$CONFIG_FILE"
    say "Stored key removed."
    exit 0
    ;;
  update|--update|upgrade|--upgrade)
    say "Updating m3claude to the latest version..."
    curl -fsSL "https://raw.githubusercontent.com/atokurn/m3claude/main/install.sh" | bash
    exit $?
    ;;
esac

# --- resolve the key -------------------------------------------------------
KEY="$(read_key)"

# Not stored yet: take it from the environment if it's there...
if [ -z "${KEY:-}" ] && [ -n "${TOKENROUTER_API_KEY:-}" ]; then
  KEY="$(trim "$TOKENROUTER_API_KEY")"
  say "Using TOKENROUTER_API_KEY from environment; saving for next time."
  save_key "$KEY" || true
fi

# ...otherwise ask for it interactively.
if [ -z "${KEY:-}" ]; then
  interactive_setup
  KEY="$(read_key)"
fi

if [ -z "${KEY:-}" ]; then
  say "No API key available. Run 'm3claude config' to set one."
  exit 1
fi

# --- launch ----------------------------------------------------------------
if ! command -v claude >/dev/null 2>&1; then
  say "claude CLI not found on PATH."
  say "Install Claude Code first: https://docs.claude.com/en/docs/claude-code"
  exit 127
fi

# Start the local translation proxy in the background.
# TokenRouter exposes an OpenAI-compatible API; claude CLI speaks Anthropic.
# proxy.py bridges the two. Install: re-run install.sh, or place proxy.py
# next to this script.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd || true)"
if [ -z "$SCRIPT_DIR" ] || [ ! -f "$SCRIPT_DIR/proxy.py" ]; then
  SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" 2>/dev/null && pwd || true)"
fi
PROXY_SCRIPT="${SCRIPT_DIR:-.}/proxy.py"

if ! command -v python3 >/dev/null 2>&1; then
  say "python3 not found on PATH."
  say "m3claude needs Python 3 to run the translation proxy."
  say "Install: brew install python3 (macOS) or your distro's package manager."
  exit 127
fi

if [ ! -f "$PROXY_SCRIPT" ]; then
  say "proxy.py not found at $PROXY_SCRIPT"
  say "Re-run the installer:"
  say "  curl -fsSL https://raw.githubusercontent.com/atokurn/m3claude/main/install.sh | bash"
  exit 1
fi

PROXY_PORT_FILE="$(mktemp -t m3claude-proxy-port)"
PROXY_LOG="$(mktemp -t m3claude-proxy-log)"

M3CLAUDE_PORT=0 \
M3CLAUDE_HOST=127.0.0.1 \
M3CLAUDE_PORT_FILE="$PROXY_PORT_FILE" \
M3CLAUDE_UPSTREAM="https://api.tokenrouter.com" \
TOKENROUTER_API_KEY="$KEY" \
  python3 "$PROXY_SCRIPT" >"$PROXY_LOG" 2>&1 &
PROXY_PID=$!

# Wait up to ~5s for the proxy to write its port file.
PROXY_PORT=""
for _ in $(seq 1 25); do
  if [ -f "$PROXY_PORT_FILE" ]; then
    PROXY_PORT="$(tr -d '[:space:]' < "$PROXY_PORT_FILE" 2>/dev/null || true)"
    if [ -n "$PROXY_PORT" ]; then
      break
    fi
  fi
  if ! kill -0 "$PROXY_PID" 2>/dev/null; then
    say "Translation proxy exited before becoming ready. Log:"
    sed 's/^/  /' "$PROXY_LOG" >&2 || true
    rm -f "$PROXY_PORT_FILE" "$PROXY_LOG"
    exit 1
  fi
  sleep 0.2
done

if [ -z "$PROXY_PORT" ] || ! kill -0 "$PROXY_PID" 2>/dev/null; then
  say "Translation proxy failed to start. Log:"
  sed 's/^/  /' "$PROXY_LOG" >&2 || true
  kill "$PROXY_PID" 2>/dev/null || true
  rm -f "$PROXY_PORT_FILE" "$PROXY_LOG"
  exit 1
fi

# Kill the proxy when claude exits (any cause).
cleanup() {
  if [ -n "${PROXY_PID:-}" ] && kill -0 "$PROXY_PID" 2>/dev/null; then
    kill "$PROXY_PID" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
  fi
  rm -f "${PROXY_PORT_FILE:-}" "${PROXY_LOG:-}" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

export ANTHROPIC_BASE_URL="http://127.0.0.1:$PROXY_PORT"
export ANTHROPIC_AUTH_TOKEN="$KEY"
export ANTHROPIC_MODEL="MiniMax-M3"
export ANTHROPIC_DEFAULT_OPUS_MODEL="MiniMax-M3"
export ANTHROPIC_DEFAULT_SONNET_MODEL="MiniMax-M3"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="MiniMax-M3"
export CLAUDE_CODE_SUBAGENT_MODEL="MiniMax-M3"
export CLAUDE_CODE_EFFORT_LEVEL="max"

exec claude --dangerously-skip-permissions "$@"
